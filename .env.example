# ============================================
# 火山引擎配置（用于文本对话、图片生成、视觉理解）
# ============================================
VITE_VOLC_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VITE_VOLC_API_KEY=your_volc_api_key_here

# 通用文本对话/策略模型
VITE_VOLC_MODEL_TEXT=dove-stone/doubao-seed-2-0-lite-260428

# 多模态/视觉理解模型
VITE_VOLC_MODEL_VISION=dove-stone/doubao-seed-1-6-vision-250815

# 图片生成/编辑模型（证件照、风格转换、美化）
VITE_VOLC_MODEL_IMAGE=dove-stone/doubao-seedream-5-0-260128

# ============================================
# 硅基流动配置（用于 OCR）
# ============================================
VITE_SILICON_BASE_URL=https://api.siliconflow.cn/v1
VITE_SILICON_API_KEY=your_silicon_api_key_here

# OCR 专用模型
VITE_SILICON_MODEL_OCR=PaddlePaddle/PaddleOCR-VL-1.5

# ============================================
# 可选配置
# ============================================
VITE_GA_ID=your_google_analytics_id

# ============================================
# Umami 统计（可选）
# ============================================
VITE_UMAMI_ENABLED=true
VITE_UMAMI_SRC=https://analytics.example.com/script.js
VITE_UMAMI_WEBSITE_ID=your_umami_website_id
